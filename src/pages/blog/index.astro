---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BlogTimeline from '../../components/BlogTimeline.astro';
import { getAllPosts } from '../../lib/blog';

const posts = getAllPosts();
---

<Layout
  title="Blog | AWS Student Builder Group UPY"
  description="Notas, talleres y noticias del AWS Student Builder Group en la Universidad Politécnica de Yucatán."
>
  <Navbar />
  <main class="relative overflow-x-hidden px-6 py-24">
    <img
      src="/vectors/bracket-smile-mint.svg"
      alt=""
      aria-hidden="true"
      class="sbg-vector sbg-vector--a right-[4%] top-28 z-0 hidden h-14 w-14 md:block lg:h-16 lg:w-16"
    />
    <img
      src="/vectors/drop-mint.svg"
      alt=""
      aria-hidden="true"
      class="sbg-vector sbg-vector--b left-[3%] top-[42%] z-0 hidden h-12 w-12 lg:block"
    />
    <img
      src="/vectors/trophy-amber.svg"
      alt=""
      aria-hidden="true"
      class="sbg-vector sbg-vector--a bottom-32 right-[5%] z-0 h-12 w-12 sm:h-14 sm:w-14"
    />

    <div class="relative z-10 mx-auto max-w-4xl">
      <div class="max-w-2xl reveal">
        <p class="font-mono text-sm text-cloud">// blog</p>
        <h1 class="font-display mt-4 text-3xl font-extrabold uppercase tracking-tight sm:text-5xl">
          Bitácora <span class="text-cloud">builder</span>
        </h1>
        <p class="mt-4 text-lg text-fog">
          Recaps de eventos, tips de AWS y lo que va pasando en la comunidad UPY — en orden cronológico.
        </p>
        <p class="mt-3 font-mono text-xs text-fog">
          <span class="text-mint">$</span> ls -lt ~/bitacora/
        </p>
      </div>

      {
        posts.length > 0 ? (
          <div class="mt-14">
            <BlogTimeline />
          </div>
        ) : (
          <div
            class="brut reveal mt-12 rounded-2xl border-dashed bg-ink/40 p-10 text-center"
            style="--brut-line: #f2f6f9; --brut-shadow: #42b4ff;"
          >
            <p class="font-mono text-sm text-fog">// próximamente</p>
            <p class="mt-3 text-paper">Aún no hay entradas publicadas.</p>
          </div>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>
