---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import EventCard from '../../components/EventCard.astro';
import EventPlaceholderCard from '../../components/EventPlaceholderCard.astro';
import { EVENT_GRID_SLOTS, getUpcomingEvents } from '../../lib/events';

const events = getUpcomingEvents();
const placeholderCount = Math.max(0, EVENT_GRID_SLOTS - events.length);
---

<Layout
  title="Eventos | AWS Student Builder Group UPY"
  description="Próximos eventos del AWS Student Builder Group en la Universidad Politécnica de Yucatán."
>
  <Navbar />
  <main class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <h1 class="text-sm font-bold uppercase tracking-wide text-accent">Eventos</h1>
        <p class="font-display mt-4 text-3xl font-light tracking-tight sm:text-5xl">
          Calendario de eventos
        </p>
        <p class="mt-4 text-lg text-muted">
          Workshops, hackathons, certificaciones y más. Únete a nuestra comunidad y despega tu carrera en la nube.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {events.map((event) => <EventCard event={event} />)}
        {Array.from({ length: placeholderCount }).map(() => <EventPlaceholderCard />)}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
