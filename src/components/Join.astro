<section id="unete" class="border-t-2 border-paper/15 px-6 py-24">
  <div
    class="brut bg-dots reveal relative mx-auto max-w-5xl overflow-hidden rounded-3xl bg-ink px-8 py-16 text-center sm:px-12 sm:py-20"
    style="--brut-line: #f2f6f9; --brut-shadow: #00e582;"
  >
    <img src="/vectors/drop-mint.svg" alt="" class="sbg-vector sbg-vector--a left-[5%] top-8 h-12 w-12 sm:h-16 sm:w-16" />
    <img src="/vectors/speaker-magenta.svg" alt="" class="sbg-vector sbg-vector--b right-[6%] bottom-8 h-14 w-14 sm:h-20 sm:w-20" />
    <img src="/vectors/trophy-purple.svg" alt="" class="sbg-vector sbg-vector--b left-[10%] bottom-6 hidden h-14 w-14 sm:block" />

    <p class="font-mono text-sm text-mint">$ sudo únete --ahora</p>

    <h2 class="mt-5 font-mono text-3xl font-bold leading-tight sm:text-5xl">
      deploy <span class="text-mint">your future.</span>
    </h2>

    <p class="mx-auto mt-6 max-w-xl text-fog">
      Únete al AWS Student Builder Group UPY, no importa tu carrera o nivel de experiencia. Solo
      necesitas ganas de aprender.
    </p>

    <div class="mt-10 flex flex-col justify-center gap-5 sm:flex-row">
      <button
        id="join-form-btn"
        type="button"
        class="brut brut-hover brut-press inline-flex cursor-pointer items-center justify-center rounded-xl bg-mint px-7 py-4 font-display text-base font-bold text-ink-deep"
        style="--brut-line: #10151b; --brut-shadow: #ad5cff;"
      >
        Llenar formulario de registro
      </button>
      <a
        href="https://linktr.ee/aws.upy"
        target="_blank"
        rel="noopener noreferrer"
        class="brut brut-hover brut-press inline-flex items-center justify-center rounded-xl bg-ink-deep px-7 py-4 font-display text-base font-bold text-paper"
        style="--brut-line: #f2f6f9; --brut-shadow: #ff57e9;"
      >
        Síguenos en redes
      </a>
    </div>
  </div>

  <div
    id="join-soon-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="join-soon-title"
    aria-hidden="true"
  >
    <button
      type="button"
      class="absolute inset-0 bg-ink-deep/80 backdrop-blur-sm"
      data-join-modal-close
      aria-label="Cerrar"
    ></button>

    <div
      class="brut relative z-10 w-full max-w-md rounded-2xl bg-ink font-mono text-sm text-left shadow-2xl"
      style="--brut-line: #161d26; --brut-shadow: #00e582;"
    >
      <div class="flex items-center justify-between gap-2 border-b-2 border-paper/15 px-4 py-3">
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-bubble"></span>
          <span class="h-3 w-3 rounded-full bg-sunset"></span>
          <span class="h-3 w-3 rounded-full bg-mint"></span>
          <span class="ml-2 text-xs text-fog">registro@upy: ~/aws-sbg</span>
        </div>
        <button
          type="button"
          class="rounded px-2 py-0.5 text-fog transition hover:bg-ink-raise hover:text-paper"
          data-join-modal-close
          aria-label="Cerrar"
        >
          ✕
        </button>
      </div>
      <div id="join-term-body" class="space-y-3 px-5 py-6 leading-relaxed" aria-live="polite">
        <p id="join-soon-title" class="min-h-[1.4em]">
          <span class="text-mint">$</span>{' '}
          <span data-term-line data-term-class="text-paper" data-term-text="aws sbg register --campus upy"></span>
          <span data-term-caret class="cursor-blink text-paper">▮</span>
        </p>
        <p class="min-h-[1.4em] text-fog">
          <span data-term-line data-term-class="text-fog" data-term-text="Verificando inscripciones..."></span>
        </p>
        <p class="min-h-[1.4em]">
          <span class="text-sunset opacity-0" data-term-bang>!</span>{' '}
          <span
            data-term-line
            data-term-class="text-mint"
            data-term-text="Próximamente se abrirán las inscripciones al club."
          ></span>
        </p>
        <p class="pt-1 min-h-[1.4em] text-fog opacity-0" data-term-prompt>
          <span class="text-mint">$</span>{' '}
          <span class="text-fog/50">enter to exit</span>{' '}
          <span class="cursor-blink text-paper">▮</span>
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const joinBtn = document.getElementById('join-form-btn');
  const joinModal = document.getElementById('join-soon-modal');
  const termCaret = joinModal?.querySelector('[data-term-caret]');
  const termBang = joinModal?.querySelector('[data-term-bang]');
  const termPrompt = joinModal?.querySelector('[data-term-prompt]');
  const termLines = joinModal ? [...joinModal.querySelectorAll('[data-term-line]')] : [];

  let typingToken = 0;
  let typingDone = false;

  const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

  const resetTerminal = () => {
    typingDone = false;
    termLines.forEach((line) => {
      line.textContent = '';
      line.className = '';
    });
    termBang?.classList.add('opacity-0');
    termPrompt?.classList.add('opacity-0');
    if (termCaret) termCaret.classList.remove('hidden');
  };

  /** Stream estilo generación de IA: chunks cortos, ritmo irregular. */
  const streamText = async (el, text, token) => {
    const cls = el.getAttribute('data-term-class') ?? '';
    el.className = cls;
    let i = 0;
    while (i < text.length) {
      if (token !== typingToken) return;
      const chunk = Math.min(text.length - i, 1 + Math.floor(Math.random() * 3));
      i += chunk;
      el.textContent = text.slice(0, i);
      await sleep(22 + Math.random() * 28);
    }
  };

  const runTerminalSequence = async () => {
    const token = ++typingToken;
    resetTerminal();
    await sleep(120);
    if (token !== typingToken) return;

    for (let index = 0; index < termLines.length; index++) {
      if (token !== typingToken) return;
      const line = termLines[index];
      const text = line.getAttribute('data-term-text') ?? '';
      if (index === 2) termBang?.classList.remove('opacity-0');
      await streamText(line, text, token);
      if (token !== typingToken) return;
      await sleep(90);
    }

    if (termCaret) termCaret.classList.add('hidden');
    termPrompt?.classList.remove('opacity-0');
    typingDone = true;
  };

  const openJoinModal = () => {
    if (!joinModal) return;
    joinModal.classList.remove('hidden');
    joinModal.classList.add('flex');
    joinModal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    void runTerminalSequence();
  };

  const closeJoinModal = () => {
    typingToken += 1;
    typingDone = false;
    if (!joinModal) return;
    joinModal.classList.add('hidden');
    joinModal.classList.remove('flex');
    joinModal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    joinBtn?.focus();
  };

  const isModalOpen = () => Boolean(joinModal && !joinModal.classList.contains('hidden'));

  joinBtn?.addEventListener('click', openJoinModal);

  joinModal?.querySelectorAll('[data-join-modal-close]').forEach((el) => {
    el.addEventListener('click', closeJoinModal);
  });

  document.addEventListener('keydown', (e) => {
    if (!isModalOpen()) return;
    if (e.key === 'Escape') {
      e.preventDefault();
      closeJoinModal();
      return;
    }
    if (e.key === 'Enter' && typingDone) {
      e.preventDefault();
      closeJoinModal();
    }
  });
</script>
