---
const tickerItems = [
  { text: 'APRENDE', color: 'text-mint' },
  { text: 'CONSTRUYE', color: 'text-cloud' },
  { text: 'CONECTA', color: 'text-grape' },
  { text: 'CERTIFÍCATE', color: 'text-sunset' },
  { text: 'DESPEGA', color: 'text-bubble' },
];
---

<section id="hero" class="hero-bg relative overflow-hidden border-b-2 border-paper/15 px-6 pb-0 pt-16 sm:pt-24">
  <div class="hero-grid" aria-hidden="true"></div>

  <img
    src="/vectors/bolt-blue.svg"
    alt=""
    class="sbg-vector sbg-vector--a z-[2] right-[3%] top-16 h-14 w-14 sm:right-[5%] sm:top-20 sm:h-20 sm:w-20"
  />
  <img
    src="/vectors/trophy-amber.svg"
    alt=""
    class="sbg-vector sbg-vector--b z-[2] bottom-14 left-[5%] hidden h-16 w-16 md:block lg:bottom-16 lg:h-20 lg:w-20"
  />
  <img
    src="/vectors/key-amber.svg"
    alt=""
    class="sbg-vector sbg-vector--a z-[2] bottom-40 right-[6%] hidden h-14 w-14 lg:block lg:h-16 lg:w-16"
  />

  <div
    class="relative z-10 mx-auto grid max-w-6xl items-center gap-10 pb-20 sm:gap-12 sm:pb-28 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] lg:gap-14 xl:gap-16"
  >
    <div class="min-w-0">
      <p class="font-mono text-xs text-fog sm:text-sm">
        <span class="text-mint">$</span> cd ~/universidad-politecnica-yucatan
      </p>

      <h1 class="font-display mt-6 text-5xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-7xl lg:text-7xl xl:text-8xl">
        <span class="block text-cloud">Aprende.</span>
        <span class="block text-mint">Construye.</span>
        <span class="block">
          <span class="text-transparent [-webkit-text-stroke:2px_#ad5cff]">Despega</span><span class="text-sunset">↗</span>
        </span>
      </h1>

      <p class="mt-8 max-w-xl text-lg text-fog sm:text-xl">
        Somos el <strong class="font-bold text-paper">AWS Student Builder Group</strong> de la UPY:
        una comunidad estudiantil que aprende, construye y crece junta usando la nube de Amazon Web
        Services.
      </p>

      <div class="mt-10 flex flex-col gap-5 sm:flex-row">
        <a
          href="#unete"
          class="brut brut-hover brut-press inline-flex items-center justify-center gap-2 rounded-xl bg-mint px-7 py-4 font-display text-base font-bold text-ink-deep"
          style="--brut-line: #10151b; --brut-shadow: #ad5cff;"
        >
          Únete al grupo
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/eventos"
          class="brut brut-hover brut-press inline-flex items-center justify-center rounded-xl bg-ink-raise px-7 py-4 font-display text-base font-bold text-paper"
          style="--brut-line: #f2f6f9; --brut-shadow: #42b4ff;"
        >
          Ver próximos eventos
        </a>
      </div>
    </div>

    <!-- Terminal de la comunidad -->
    <div
      class="brut brut-hover w-full max-w-md rotate-1 justify-self-center rounded-2xl bg-ink font-mono text-sm lg:max-w-none lg:justify-self-end"
      style="--brut-line: #161d26; --brut-shadow: #ff9900;"
    >
      <div class="flex items-center gap-2 border-b-2 border-paper/15 px-4 py-3">
        <span class="h-3 w-3 rounded-full bg-bubble"></span>
        <span class="h-3 w-3 rounded-full bg-sunset"></span>
        <span class="h-3 w-3 rounded-full bg-mint"></span>
        <span class="ml-3 text-xs text-fog">builder@upy: ~/aws-sbg</span>
      </div>
      <div class="space-y-2.5 px-5 py-6 text-[13px] leading-relaxed sm:text-sm">
        <p><span class="text-mint">$</span> <span class="text-paper">aws sbg init --campus upy</span></p>
        <p class="text-fog">Inicializando comunidad builder...</p>
        <p><span class="text-mint">✔</span> <span class="text-fog">comunidad</span> <span class="text-cloud">lista</span></p>
        <p><span class="text-mint">✔</span> <span class="text-fog">talleres y hackathons</span> <span class="text-grape">cargados</span></p>
        <p><span class="text-mint">✔</span> <span class="text-fog">rutas de certificación</span> <span class="text-sunset">activadas</span></p>
        <p class="pt-2"><span class="text-mint">$</span> <span class="cursor-blink text-paper">./unete --ahora</span></p>
      </div>
    </div>
  </div>

  <!-- Ticker marquee -->
  <div class="marquee relative z-10 -mx-6 border-t-2 border-paper/15 bg-ink py-4" aria-hidden="true">
    <div class="marquee-track">
      {
        [0, 1].map(() => (
          <div class="flex shrink-0 items-center">
            {tickerItems.map((item) => (
              <span class={`${item.color} flex items-center font-mono text-lg font-bold tracking-wide sm:text-xl`}>
                <span class="px-6">{item.text}</span>
                <span class="text-paper/40">✦</span>
              </span>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const hero = document.getElementById('hero');
  const grid = hero?.querySelector('.hero-grid');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && grid && !reducedMotion) {
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      grid.style.setProperty('--gx', `${e.clientX - rect.left}px`);
      grid.style.setProperty('--gy', `${e.clientY - rect.top}px`);
      hero.classList.add('hero-grid--active');
    });

    hero.addEventListener('mouseleave', () => {
      hero.classList.remove('hero-grid--active');
    });
  }
</script>
