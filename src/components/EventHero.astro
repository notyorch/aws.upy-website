---
import { buttonVariants } from '../lib/heroui';
import type { Event } from '../lib/events';

interface Props {
  event: Event;
}

const { event } = Astro.props;

const ctaClass = buttonVariants({ size: 'lg', fullWidth: true });

const eventDate = new Date(`${event.date}T12:00:00`);
const calendarMonth = eventDate
  .toLocaleDateString('es-MX', { month: 'short' })
  .replace('.', '')
  .toUpperCase();
const calendarDay = eventDate.getDate();

const heroTitle = event.heroTitle ?? event.title;
const timeDisplay = event.timeRange ?? event.time;
---

<section class="border-b border-border px-6 py-10 sm:py-14">
  <div class="mx-auto max-w-6xl">
    <a href="/eventos" class="text-sm font-bold text-accent hover:opacity-80">
      ← Volver a eventos
    </a>

    <div class="mt-8 grid items-start gap-8 lg:grid-cols-[minmax(260px,360px)_1fr] lg:gap-12 xl:gap-16">
      {
        event.thumbnail && (
          <div class="mx-auto w-full max-w-[360px] lg:mx-0">
            <div class="aspect-square overflow-hidden rounded-2xl border border-border bg-surface">
              <img
                src={event.thumbnail}
                alt={event.title}
                class="h-full w-full object-contain"
              />
            </div>
          </div>
        )
      }

      <div class="flex min-w-0 flex-col">
        <h1 class="font-display text-3xl font-light leading-tight tracking-tight sm:text-4xl lg:text-[2.75rem] lg:leading-[1.15]">
          {heroTitle}
        </h1>

        <div class="mt-8 space-y-5">
          <div class="flex items-center gap-4">
            <div
              class="flex h-14 w-14 shrink-0 flex-col overflow-hidden rounded-xl border border-border bg-surface"
              aria-hidden="true"
            >
              <div class="bg-accent px-1 py-1 text-center text-[10px] font-bold uppercase tracking-wide text-accent-foreground">
                {calendarMonth}
              </div>
              <div class="flex flex-1 items-center justify-center text-xl font-bold">
                {calendarDay}
              </div>
            </div>
            <div>
              <p class="font-bold capitalize text-foreground">{event.dateFormatted}</p>
              {
                timeDisplay && (
                  <p class="mt-0.5 text-sm text-muted">{timeDisplay}</p>
                )
              }
            </div>
          </div>

          {
            event.location && (
              <div class="flex items-start gap-4">
                <div
                  class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl border border-border bg-surface text-muted"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <div class="min-w-0 pt-1">
                  {
                    event.locationUrl ? (
                      <a
                        href={event.locationUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 font-bold text-foreground transition hover:text-accent"
                      >
                        {event.location}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                        </svg>
                      </a>
                    ) : (
                      <p class="font-bold text-foreground">{event.location}</p>
                    )
                  }
                  {
                    event.locationRegion && (
                      <p class="mt-0.5 text-sm text-muted">{event.locationRegion}</p>
                    )
                  }
                </div>
              </div>
            )
          }
        </div>

        {
          event.meetupUrl && (
            <div class="mt-10 max-w-md">
              <a
                href={event.meetupUrl}
                target="_blank"
                rel="noopener noreferrer"
                class={`${ctaClass} justify-center`}
              >
                Inscripción
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
