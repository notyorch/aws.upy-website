---
const benefits = [
  {
    title: 'Contenido oficial AWS',
    description: 'Acceso a contenido oficial de AWS Educate y AWS Academy.',
    icon: 'educate',
    color: '#00e582',
    text: 'text-mint',
  },
  {
    title: 'Mentoría entre pares',
    description: 'Acompañamiento para preparar y obtener certificaciones AWS.',
    icon: 'certification',
    color: '#42b4ff',
    text: 'text-cloud',
  },
  {
    title: 'Proyectos colaborativos',
    description: 'Iniciativas en equipo con impacto en la comunidad universitaria.',
    icon: 'projects',
    color: '#ad5cff',
    text: 'text-grape',
  },
  {
    title: 'Red regional SBG',
    description: 'Conexión con otros Student Builder Groups de la región.',
    icon: 'network',
    color: '#ff9900',
    text: 'text-sunset',
  },
];
---

<section id="sobre-nosotros" class="relative overflow-hidden px-6 py-24">
  <img src="/vectors/ladder-purple.svg" alt="" class="sbg-vector sbg-vector--b right-[4%] top-16 hidden h-16 w-16 lg:block" />

  <div class="mx-auto grid max-w-6xl gap-16 lg:grid-cols-2 lg:items-center">
    <div class="reveal">
      <p class="font-mono text-sm text-mint">// sobre-nosotros</p>
      <h2 class="font-display mt-4 text-4xl font-extrabold uppercase tracking-tight sm:text-5xl">
        Una comunidad de <span class="text-mint">builders</span>
      </h2>
      <p class="mt-6 text-fog">
        El AWS Student Builder Group UPY es un grupo estudiantil respaldado por Amazon Web
        Services que reúne a estudiantes de la Universidad Politécnica de Yucatán interesados en
        la nube, la inteligencia artificial y el desarrollo de software.
      </p>
      <p class="mt-4 text-fog">
        Aprendemos haciendo: talleres prácticos, hackathons, rutas de certificación y proyectos
        reales que conectan la teoría del salón de clases con la industria tecnológica.
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        <div
          class="brut brut-hover -rotate-1 rounded-2xl bg-ink p-6"
          style="--brut-line: #f2f6f9; --brut-shadow: #42b4ff;"
        >
          <p class="font-mono text-xs text-cloud">[ misión ]</p>
          <p class="mt-3 text-sm text-paper">
            Impulsar el talento en la nube dentro de la comunidad UPY.
          </p>
        </div>
        <div
          class="brut brut-hover rotate-1 rounded-2xl bg-ink p-6"
          style="--brut-line: #f2f6f9; --brut-shadow: #ff57e9;"
        >
          <p class="font-mono text-xs text-bubble">[ visión ]</p>
          <p class="mt-3 text-sm text-paper">
            Ser referencia estudiantil de innovación cloud en Yucatán.
          </p>
        </div>
      </div>
    </div>

    <div class="reveal">
      <div
        class="brut rounded-2xl bg-ink p-6 sm:p-8"
        style="--brut-line: #f2f6f9; --brut-shadow: #00e582;"
      >
        <p class="font-display text-2xl font-extrabold uppercase tracking-tight">¿Por qué unirte?</p>
        <p class="mt-1 font-mono text-xs text-fog">$ cat beneficios.md</p>

        <ul class="mt-6 space-y-4">
          {
            benefits.map((benefit) => (
              <li
                class="brut brut-hover flex gap-4 rounded-xl bg-ink-deep p-4"
                style={`--brut-line: ${benefit.color}; --brut-shadow: ${benefit.color};`}
              >
                <div class={`${benefit.text} flex h-12 w-12 shrink-0 items-center justify-center`}>
                  {
                    benefit.icon === 'educate' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                        <path d="M8 14l16-8 16 8-16 8-16-8z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
                        <path d="M8 14v14l16 8 16-8V14" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
                        <path d="M24 22v14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                      </svg>
                    )
                  }
                  {
                    benefit.icon === 'certification' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                        <path d="M14 8h20l4 8v18a4 4 0 01-4 4H14a4 4 0 01-4-4V16l4-8z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
                        <path d="M20 26l4 4 8-9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )
                  }
                  {
                    benefit.icon === 'projects' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                        <rect x="6" y="22" width="14" height="14" rx="2" stroke="currentColor" stroke-width="2.5"/>
                        <rect x="28" y="22" width="14" height="14" rx="2" stroke="currentColor" stroke-width="2.5"/>
                        <rect x="17" y="10" width="14" height="14" rx="2" stroke="currentColor" stroke-width="2.5"/>
                      </svg>
                    )
                  }
                  {
                    benefit.icon === 'network' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                        <circle cx="24" cy="12" r="5" stroke="currentColor" stroke-width="2.5"/>
                        <circle cx="10" cy="34" r="5" stroke="currentColor" stroke-width="2.5"/>
                        <circle cx="38" cy="34" r="5" stroke="currentColor" stroke-width="2.5"/>
                        <path d="M21 16l-8 14M27 16l8 14M15 34h18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                      </svg>
                    )
                  }
                </div>
                <div class="min-w-0 pt-0.5">
                  <p class="text-sm font-bold text-paper">{benefit.title}</p>
                  <p class="mt-1 text-sm leading-relaxed text-fog">{benefit.description}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
